    "@zip.js/zip.js": "^2.8.14",
    "antlr4": "4.9.3",
    "async-mutex": "0.4.0",
    "axios": "1.12.0",
    "bignumber.js": "9.1.1",
    "chart.js": "3.9.1",
    "chartjs-adapter-moment": "1.0.1",
    "decamelize": "^6.0.1",
    "eslint": "^9.0.0",
    "flush-promises": "^1.0.2",
    "form-data": "4.0.4",
    "highlight.js": "^11.11.1",
    "iconoir": "^6.11.0",
    "js-sha256": "^0.11.1",
    "jwt-decode": "^3.1.2",
    "lodash.debounce": "^4.0.8",
    "lowlight": "^3.3.0",
    "markdown-it": "13.0.2",
    "markdown-it-regexp": "^0.4.0",
    "markdown-it-task-lists": "^2.1.1",
    "mitt": "^3.0.1",
    "moment": "^2.30.1",
    "moment-guess": "^1.2.4",
    "moment-timezone": "0.5.43",
    "normalize.css": "^8.0.1",
    "nuxt": "^3.20.1",
    "papaparse": "5.4.1",
    "path-to-regexp": "8.2.0",
    "posthog-js": "^1.232.4",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "~1.70.0",
    "thenby": "^1.3.4",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.9",
    "tldjs": "^2.3.1",
    "ulid": "^3.0.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.5.25",
